WEB_ORIGIN=http://localhost:3100 # Default: http://localhost:3100, for allow all origins use '*'. On mobile use your PC IP (e.g. http://192.168.1.10:3100)
SOCKET_URL=http://localhost:3101 # Default: http://localhost:3101. On mobile use your PC IP (e.g. http://192.168.1.10:3101)
SOCKET_PORT=3101 # Default: 3101 (Socket server port). Supports legacy env var: SOCKER_PORT
NEXT_PUBLIC_API_URL=http://localhost:8080
TELEGRAM_BOT_TOKEN= # Optional: True/False natijalarini Telegramga yuborish uchun
